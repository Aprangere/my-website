---
import BaseLayout from '../layouts/BaseLayout.astro';
import { translations } from '../i18n/translations';
const en = translations.en.services;
const fr = translations.fr.services;
---

<BaseLayout title="Services — Arman Prangere">

  <div class="mb-14">
    <h1 class="text-2xl sm:text-3xl font-bold text-stone-900 dark:text-stone-100 tracking-tight mb-6"
      data-en={en.title} data-fr={fr.title}>{en.title}</h1>
    <p class="text-lg text-stone-600 dark:text-stone-400 leading-relaxed max-w-2xl"
      data-en={en.intro} data-fr={fr.intro}>{en.intro}</p>
  </div>

  <!-- I can help you -->
  <div class="mb-14">
    <h2 class="text-xs font-semibold text-stone-400 dark:text-stone-500 uppercase tracking-widest mb-6"
      data-en={en.helpTitle} data-fr={fr.helpTitle}>{en.helpTitle}</h2>
    <ul class="grid sm:grid-cols-2 gap-x-10 gap-y-3">
      {en.helpItems.map((item, i) => (
        <li class="flex items-start gap-3 text-stone-700 dark:text-stone-300">
          <span class="mt-1.5 text-salmon shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </span>
          <span data-en={item} data-fr={fr.helpItems[i]}>{item}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Areas of practice -->
  <div class="mb-14">
    <h2 class="text-xs font-semibold text-stone-400 dark:text-stone-500 uppercase tracking-widest mb-6"
      data-en={en.areasTitle} data-fr={fr.areasTitle}>{en.areasTitle}</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {en.areas.map((area, i) => (
        <div class="rounded-2xl bg-lm-card dark:bg-dm-card border border-lm-border dark:border-dm-border p-6">
          <h3 class="font-semibold text-stone-900 dark:text-stone-100 mb-2"
            data-en={area.title} data-fr={fr.areas[i].title}>{area.title}</h3>
          <p class="text-stone-500 dark:text-stone-400 leading-relaxed"
            data-en={area.body} data-fr={fr.areas[i].body}>{area.body}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Offerings -->
  <div class="mb-10">
    <h2 class="text-xs font-semibold text-stone-400 dark:text-stone-500 uppercase tracking-widest mb-6"
      data-en={en.offeringsTitle} data-fr={fr.offeringsTitle}>{en.offeringsTitle}</h2>
    <div class="space-y-3">
      {en.offerings.map((o, i) => (
        <details class="rounded-2xl bg-lm-card dark:bg-dm-card border border-lm-border dark:border-dm-border overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none hover:bg-lm-border/20 dark:hover:bg-dm-border/30 transition-colors">
            <span class="font-semibold text-stone-800 dark:text-stone-200"
              data-en={o.label} data-fr={fr.offerings[i].label}>{o.label}</span>
            <span class="details-icon text-salmon text-xl font-light ml-4 leading-none">+</span>
          </summary>
          <div class="px-6 pb-5 pt-1">
            <p class="text-stone-600 dark:text-stone-400 leading-relaxed"
              data-en={o.body} data-fr={fr.offerings[i].body}>{o.body}</p>
          </div>
        </details>
      ))}
    </div>
  </div>

  <p class="text-stone-600 dark:text-stone-400 italic text-sm border-l-2 border-lm-border dark:border-dm-border pl-4 mb-14"
    data-en={en.pricing} data-fr={fr.pricing}>{en.pricing}</p>

  <!-- Calendly -->
  <div>
    <h2 class="text-xs font-semibold text-stone-400 dark:text-stone-500 uppercase tracking-widest mb-4"
      data-en={en.contactTitle} data-fr={fr.contactTitle}>{en.contactTitle}</h2>
    <p class="text-stone-600 dark:text-stone-400 leading-relaxed mb-8"
      data-en={en.contactIntro} data-fr={fr.contactIntro}>{en.contactIntro}</p>
    <div class="calendly-inline-widget rounded-2xl overflow-hidden border border-lm-border dark:border-dm-border"
         data-url="https://calendly.com/arman-behavior/30min"
         style="min-width:280px;height:660px;">
    </div>
    <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
  </div>

</BaseLayout>
