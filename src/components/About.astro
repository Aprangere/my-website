---
import { translations } from '../i18n/translations';
const en = translations.en.about;
const fr = translations.fr.about;
---

<section class="max-w-2xl mx-auto mb-6 px-4">
  <div class="bg-white dark:bg-stone-900 rounded-2xl shadow-lg ring-1 ring-stone-900/5 dark:ring-white/5 p-8 sm:p-12">

    <h2 class="text-2xl sm:text-3xl font-bold text-stone-900 dark:text-white mb-6 tracking-tight" data-en={en.title} data-fr={fr.title}>{en.title}</h2>

    <p class="text-stone-700 dark:text-stone-300 text-lg leading-relaxed mb-4" data-en={en.p1} data-fr={fr.p1}>{en.p1}</p>
    <p class="text-stone-700 dark:text-stone-300 text-lg leading-relaxed mb-8" data-en={en.p2} data-fr={fr.p2}>{en.p2}</p>

    <details class="border border-stone-100 dark:border-stone-700 rounded-xl overflow-hidden mb-8">
      <summary class="flex items-center justify-between px-5 py-4 cursor-pointer bg-stone-50 dark:bg-stone-800 hover:bg-stone-100 dark:hover:bg-stone-700/80 transition-colors select-none">
        <span class="font-semibold text-stone-800 dark:text-stone-100 text-lg" data-en={en.detailsLabel} data-fr={fr.detailsLabel}>{en.detailsLabel}</span>
        <span class="details-icon text-accent text-2xl font-light ml-4">+</span>
      </summary>
      <div class="px-5 py-5 bg-white dark:bg-stone-900">
        <p class="text-stone-700 dark:text-stone-300 leading-relaxed text-lg" data-en={en.detailsBody} data-fr={fr.detailsBody}>{en.detailsBody}</p>
      </div>
    </details>

    <a
      href="#contact"
      class="inline-block bg-accent text-white font-semibold px-7 py-3 rounded-xl shadow-md hover:bg-accent-dark transition-colors duration-200 tracking-wide"
      data-en={en.cta}
      data-fr={fr.cta}
    >
      {en.cta}
    </a>
  </div>
</section>
