---
import { translations } from '../i18n/translations';
const en = translations.en.nav;
const fr = translations.fr.nav;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const active = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="sticky top-0 z-50 bg-lm-bg/90 dark:bg-dm-bg/90 backdrop-blur-md border-b border-lm-border/50 dark:border-dm-border/60">
  <div class="max-w-4xl mx-auto px-5 h-14 flex items-center justify-between gap-4">

    <!-- Left: language flag toggle -->
    <button id="lang-toggle" aria-label="Switch language"
      class="flex items-center gap-2 text-sm font-medium text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors shrink-0">
      <img id="flag-display" src="/flags/fr.svg" class="w-5 h-auto rounded-sm" alt="FR" />
      <span id="lang-label" class="text-xs hidden sm:inline">FR</span>
    </button>

    <!-- Centre: nav -->
    <nav class="flex items-center gap-0.5 text-sm font-medium">
      {[
        { href: '/',          en: en.home,     fr: fr.home },
        { href: '/research',  en: en.research,  fr: fr.research },
        { href: '/services',  en: en.services,  fr: fr.services },
      ].map(link => (
        <a
          href={link.href}
          data-en={link.en}
          data-fr={link.fr}
          class={`px-3 py-1.5 rounded-lg whitespace-nowrap transition-colors duration-150 ${
            active(link.href)
              ? 'text-salmon font-semibold'
              : 'text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white hover:bg-stone-100 dark:hover:bg-stone-800/60'
          }`}
        >{link.en}</a>
      ))}
    </nav>

    <!-- Right: dark mode toggle -->
    <button id="dark-toggle" aria-label="Toggle dark mode"
      class="w-8 h-8 flex items-center justify-center rounded-lg text-stone-400 dark:text-stone-500 hover:text-stone-900 dark:hover:text-white hover:bg-stone-100 dark:hover:bg-stone-800/60 transition-colors shrink-0">
      <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
      </svg>
      <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
      </svg>
    </button>

  </div>
</header>

<script>
  // Dark mode
  const darkBtn = document.getElementById('dark-toggle')!;
  const moon = document.getElementById('icon-moon')!;
  const sun  = document.getElementById('icon-sun')!;
  function applyTheme(dark: boolean) {
    document.documentElement.classList.toggle('dark', dark);
    moon.classList.toggle('hidden', dark);
    sun.classList.toggle('hidden', !dark);
  }
  applyTheme(document.documentElement.classList.contains('dark'));
  darkBtn.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
    applyTheme(!isDark);
  });

  // Language
  const langBtn   = document.getElementById('lang-toggle')!;
  const flagEl    = document.getElementById('flag-display') as HTMLImageElement;
  const langLabel = document.getElementById('lang-label')!;
  let lang: 'en' | 'fr' = (localStorage.getItem('lang') as 'en' | 'fr') || 'en';
  const flags  = { en: '/flags/fr.svg', fr: '/flags/gb.svg' };
  const labels = { en: 'FR',            fr: 'EN'            };

  function applyLang(l: 'en' | 'fr') {
    document.querySelectorAll<HTMLElement>('[data-en]').forEach(el => {
      el.textContent = l === 'fr' ? (el.dataset.fr ?? '') : (el.dataset.en ?? '');
    });
    flagEl.src  = flags[l];
    flagEl.alt  = labels[l];
    langLabel.textContent = labels[l];
    document.documentElement.lang = l;
  }
  applyLang(lang);
  langBtn.addEventListener('click', () => {
    lang = lang === 'en' ? 'fr' : 'en';
    localStorage.setItem('lang', lang);
    applyLang(lang);
  });
</script>
