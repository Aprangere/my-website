---
import { translations } from '../i18n/translations';
const en = translations.en.footer;
const fr = translations.fr.footer;
---

<footer class="border-t border-stone-200/60 dark:border-stone-800/60 mt-8">
  <div class="max-w-4xl mx-auto px-5 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex gap-5">
      <a href="mailto:arman.behavior@gmail.com" aria-label="Email"
         class="text-stone-400 hover:text-salmon transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/arman-prangere-1224791a6/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
         class="text-stone-400 hover:text-salmon transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://substack.com/@armanphil" target="_blank" rel="noopener noreferrer" aria-label="Substack"
         class="text-stone-400 hover:text-salmon transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
        </svg>
      </a>
    </div>
    <p class="text-xs text-stone-400 dark:text-stone-600"
      data-en={en.copy} data-fr={fr.copy}>{en.copy}</p>
  </div>
</footer>
