<button
  id="lang-toggle"
  aria-label="Switch language"
  class="fixed top-4 left-4 z-50 bg-accent text-white text-sm font-semibold px-3 py-1.5 rounded-lg shadow hover:bg-accent-dark transition-colors duration-200 tracking-wide"
>
  FR
</button>

<script>
  const btn = document.getElementById('lang-toggle')!;
  let lang: 'en' | 'fr' = (localStorage.getItem('lang') as 'en' | 'fr') || 'en';

  function applyLang(l: 'en' | 'fr') {
    document.querySelectorAll<HTMLElement>('[data-en]').forEach((el) => {
      el.textContent = l === 'fr' ? (el.dataset.fr ?? '') : (el.dataset.en ?? '');
    });
    btn.textContent = l === 'fr' ? 'EN' : 'FR';
    document.documentElement.lang = l;
  }

  applyLang(lang);

  btn.addEventListener('click', () => {
    lang = lang === 'en' ? 'fr' : 'en';
    localStorage.setItem('lang', lang);
    applyLang(lang);
  });
</script>
