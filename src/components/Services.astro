---
import { translations } from '../i18n/translations';
const en = translations.en.services;
const fr = translations.fr.services;
---

<section class="max-w-2xl mx-auto mb-6 px-4">
  <div class="bg-white dark:bg-stone-900 rounded-2xl shadow-lg ring-1 ring-stone-900/5 dark:ring-white/5 p-8 sm:p-12">

    <h2 class="text-2xl sm:text-3xl font-bold text-stone-900 dark:text-white mb-6 tracking-tight" data-en={en.title} data-fr={fr.title}>{en.title}</h2>

    <p class="text-stone-700 dark:text-stone-300 text-lg leading-relaxed mb-2" data-en={en.intro} data-fr={fr.intro}>{en.intro}</p>
    <p class="text-stone-600 dark:text-stone-400 leading-relaxed mb-8" data-en={en.framework} data-fr={fr.framework}>{en.framework}</p>

    <p class="font-semibold text-stone-900 dark:text-stone-100 text-lg mb-4" data-en={en.helpTitle} data-fr={fr.helpTitle}>{en.helpTitle}</p>

    <ul class="space-y-3 mb-8">
      {en.items.map((item, i) => (
        <li class="flex items-start gap-3 text-stone-700 dark:text-stone-300 text-lg">
          <span class="mt-1.5 text-accent flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </span>
          <span data-en={item} data-fr={fr.items[i]}>{item}</span>
        </li>
      ))}
    </ul>

    <p class="text-stone-500 dark:text-stone-500 italic mb-8 text-sm border-l-2 border-accent/40 pl-4" data-en={en.pricing} data-fr={fr.pricing}>{en.pricing}</p>

    <div class="space-y-2 mb-8">
      {en.offerings.map((o, i) => (
        <details class="border border-stone-100 dark:border-stone-700 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer bg-stone-50 dark:bg-stone-800 hover:bg-stone-100 dark:hover:bg-stone-700/80 transition-colors select-none">
            <span class="font-semibold text-stone-800 dark:text-stone-100 text-lg" data-en={o.label} data-fr={fr.offerings[i].label}>{o.label}</span>
            <span class="details-icon text-accent text-2xl font-light ml-4">+</span>
          </summary>
          <div class="px-5 py-5 bg-white dark:bg-stone-900">
            <p class="text-stone-700 dark:text-stone-300 leading-relaxed text-lg" data-en={o.body} data-fr={fr.offerings[i].body}>{o.body}</p>
          </div>
        </details>
      ))}
    </div>

    <a
      href="#contact"
      class="inline-block bg-accent text-white font-semibold px-7 py-3 rounded-xl shadow-md hover:bg-accent-dark transition-colors duration-200 tracking-wide"
      data-en={en.cta}
      data-fr={fr.cta}
    >
      {en.cta}
    </a>
  </div>
</section>
